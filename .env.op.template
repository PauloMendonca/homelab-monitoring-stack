# 1Password secret reference template for monitoring-stack.
#
# Copy to .env.op and replace <vault_id>/<item_id> with your real IDs.
# Used by: scripts/run-with-1password.sh via `op run --env-file=.env.op`
#
# To find your vault/item IDs:
#   op vault list
#   op item list --vault <vault_id>
#
# .env.op is gitignored. This template is safe to commit.

# ── Grafana ────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=op://<vault_id>/<grafana_admin_user_item_id>/password
GRAFANA_ADMIN_PASSWORD=op://<vault_id>/<grafana_admin_password_item_id>/password
GRAFANA_ROOT_URL=op://<vault_id>/<grafana_root_url_item_id>/password

# ── Grafana MCP (profile: mcp) ────────────────────────────────────────────
GRAFANA_MCP_SERVICE_ACCOUNT_TOKEN=op://<vault_id>/<grafana_mcp_token_item_id>/password
GRAFANA_MCP_ORG_ID=op://<vault_id>/<grafana_mcp_org_id_item_id>/password
GRAFANA_MCP_GRAFANA_URL=op://<vault_id>/<grafana_mcp_url_item_id>/password

# ── Prometheus ─────────────────────────────────────────────────────────────
PROMETHEUS_RETENTION=op://<vault_id>/<prometheus_retention_item_id>/password

# ── pfSense SSH exporter ───────────────────────────────────────────────────
PFSENSE_HOST=op://<vault_id>/<pfsense_host_item_id>/password
PFSENSE_SSH_USER=op://<vault_id>/<pfsense_ssh_user_item_id>/password

# ── pfSense API (WAN guard) ───────────────────────────────────────────────
PFSENSE_API_BASE_URL=op://<vault_id>/<pfsense_api_base_url_item_id>/password
PFSENSE_API_CLIENT_ID=op://<vault_id>/<pfsense_api_client_id_item_id>/password
PFSENSE_API_CLIENT_TOKEN=op://<vault_id>/<pfsense_api_client_token_item_id>/password
PFSENSE_API_VERIFY_TLS=op://<vault_id>/<pfsense_api_verify_tls_item_id>/password

# ── WhatsApp / Evolution API ──────────────────────────────────────────────
EVOLUTION_BASE_URL=op://<vault_id>/<evolution_base_url_item_id>/password
EVOLUTION_INSTANCE=op://<vault_id>/<evolution_instance_item_id>/password
EVOLUTION_API_KEY=op://<vault_id>/<evolution_api_key_item_id>/password
WHATSAPP_TO=op://<vault_id>/<whatsapp_to_item_id>/password
WHATSAPP_TO_GENERAL=op://<vault_id>/<whatsapp_to_general_item_id>/password
WHATSAPP_TO_CRITICAL=op://<vault_id>/<whatsapp_to_critical_item_id>/password
ALERT_SOURCE=op://<vault_id>/<alert_source_item_id>/password

# ── WhatsApp inbound webhook (alert-router Phase 1) ─────────────────────
EVOLUTION_WEBHOOK_SECRET=op://<vault_id>/<evolution_webhook_secret_item_id>/password
ALLOWED_WHATSAPP_SENDERS=op://<vault_id>/<allowed_whatsapp_senders_item_id>/password

# ── Notify API (profile: nextgen) ─────────────────────────────────────────
NOTIFY_API_URL=op://<vault_id>/<notify_api_url_item_id>/password
NOTIFY_API_KEY=op://<vault_id>/<notify_api_key_item_id>/password

# ── DEYE Solar Inverters ──────────────────────────────────────────────────
DEYE_INVERTERS=op://<vault_id>/<deye_inverters_item_id>/password

# ── Mode-Switch remote executor (Phase 2) ─────────────────────────────────
# Restricted SSH key for alert-router -> 10.10.11.5 mode-switch
MODE_SWITCH_SSH_KEY=op://<vault_id>/<mode_switch_ssh_key_item_id>/password
MODE_SWITCH_HOST=10.10.11.5
MODE_SWITCH_SSH_USER=ubuntu
MODE_SWITCH_TIMEOUT_SECONDS=10
